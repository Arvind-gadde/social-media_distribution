# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-64
APP_ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/contentflow

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ── Token Encryption (Fernet) — protects platform OAuth tokens at rest ────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=CHANGE-ME-generate-with-fernet

# ── OAuth — Google Login ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Object Storage (MinIO locally, S3 in production) ─────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=contentflow-media
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/contentflow-media

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Platform OAuth Apps ───────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ── Web Push Notifications ────────────────────────────────────────────────
# Generate: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=admin@yourapp.com
